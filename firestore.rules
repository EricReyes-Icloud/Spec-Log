rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // subscribe — solo accesible via Admin SDK (API routes), bloqueado para clientes
    match /subscribe/{doc} {
      allow read, write: if false;
    }
    // newsletters — admins autenticados con Firebase Auth
    match /newsletters/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
